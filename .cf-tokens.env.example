# Cloudflare API tokens for pitcast deploy automation.
# Copy this file to `.cf-tokens.env` and fill in real tokens. The real file is
# gitignored — never commit secrets.
#
# Create tokens at: https://dash.cloudflare.com/profile/api-tokens
#
# Token 1: Cache Purge (Zone | Cache Purge | Purge, austenite.org)
CF_PURGE_TOKEN=

# Token 2: DNS Edit (Zone | DNS | Edit, austenite.org) — only needed for
# DNS-record adjustments; deploy.sh doesn't require it for normal operation.
CF_DNS_TOKEN=

# Zone + account IDs (these are not secret; included for self-contained config)
CF_ZONE_AUSTENITE_ORG=03852221945c9d49e87018271507764b
CF_ACCOUNT=549280c75f80803eb6c796571e94e1b6
